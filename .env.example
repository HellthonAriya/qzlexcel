# توکن ربات که از @BotFather می‌گیرید
BOT_TOKEN=

# مسیر فایل اکسل منبع (همان فرمت سه‌شیتی: انسانی/تجربی/ریاضی)
EXCEL_PATH=data/source.xlsx

# مسیر دیتابیس ذخیره وضعیت‌ها (خودکار ساخته می‌شود)
DB_PATH=data/state.db

# تعداد ردیف نمایش داده شده در هر صفحه
PAGE_SIZE=5

# شناسه عددی کاربران مجاز تلگرام، جدا شده با کاما. خالی = بدون محدودیت (توصیه نمی‌شود)
ALLOWED_USER_IDS=
